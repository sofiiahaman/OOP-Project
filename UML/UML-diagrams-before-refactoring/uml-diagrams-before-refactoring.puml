' Interaction overview diagram
@startuml
title Library Management System - Interaction Overview Diagram

skinparam monochrome true
skinparam shadowing false
skinparam conditionStyle diamond

|User|
start

:Start Application;
note right: MainWindow Initialization

partition "Interaction: Authentication" {
    :Display Login/Signup Window;
    if (User has account?) then (yes)
        :sd Login Logic;
        note left: Sequence: checkLogin(), getUserRole()
    else (no)
        :sd Signup Logic;
        note left: Sequence: addUser()
    endif
}

if (Auth Successful?) then (yes)
    if (Role == "Admin") then
        partition "Interaction: Admin Workflow" {
            :Show AdminMenu;
            fork
                :sd Manage Books;
                note right: Add/View/Edit Books
            fork again
                :sd Manage Students;
            fork again
                :sd Circulation;
                note right: Issue/Return Operations
            end fork
        }
    else (Role == "Student")
        partition "Interaction: Student Workflow" {
            :Show StudentMenu;
            :sd Browse Library;
        }
    endif
else (no/cancel)
    stop
endif

:Logout;
stop

@enduml


