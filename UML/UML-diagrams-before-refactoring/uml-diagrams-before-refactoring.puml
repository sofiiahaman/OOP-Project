' Composite structure diagram
@startuml
title Library Management System - Composite Structure Diagram

skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

package "System Architecture" {

    component "AdminMenu : QMainWindow" <<component>> {
        port "UI Signals" as P1
        port "DB Access" as P2
        
        [ui : Ui::AdminMenu] <<part>>
        [db : Database] <<part>>
        
        P1 - [ui]
        [ui] ..> [db] : "invokes stats/methods"
        [db] - P2
    }

    component "LoginWindow : QDialog" <<component>> {
        port "User Input" as LP1
        port "Auth Provider" as LP2
        
        [ui : Ui::LoginWindow] <<part>>
        [db_ptr : Database*] <<reference>>
        
        LP1 - [ui]
        [ui] --> [db_ptr] : "validates credentials"
        [db_ptr] - LP2
    }

    component "Database" <<component>> {
        port "SQL Interface" as DB_P
        [internal_db : QSqlDatabase] <<part>>
        [queries : QSqlQuery] <<part>>
        
        DB_P - [internal_db]
        [internal_db] -- [queries]
    }
    
    component "AddBooks : QDialog" <<component>> {
        port "Form Data" as ABP1
        [ui : Ui::AddBooks] <<part>>
        [validator : QLineEdit] <<part>>
        
        ABP1 - [ui]
        [ui] ..> [validator] : "validates input"
    }
}

'--- External Connectors ---

[AdminMenu] --( P2 : "uses"
P2 )-- [Database] : "provides"

[LoginWindow] --( LP2 : "uses"
LP2 )-- [Database] : "provides"

note right of [AdminMenu]
  Internal structure shows that 
  AdminMenu owns its Database instance.
end note

note bottom of [LoginWindow]
  LoginWindow uses a pointer (reference) 
  to a Database instance managed elsewhere.
end note

@enduml

