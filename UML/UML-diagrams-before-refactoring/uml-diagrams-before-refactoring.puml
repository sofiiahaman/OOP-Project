' Activity diagram
@startuml
title Library Management System - Activity Diagram

start

:Launch Application (MainWindow);

if (Has Account?) then (yes)
  :Open LoginWindow;
  repeat
    :Enter Username and Password;
    :Database Validates Credentials;
  backward:Show Error Message;
  repeat while (Credentials Valid?) is (no)
  :Emit loginSuccessful(role);
else (no)
  :Open SignupWindow;
  :Enter Registration Details;
  :Database: addUser();
  :Emit signupSuccessful("student");
endif

if (Role?) then (Admin)
  :Open AdminMenu;
  fork
    :View Dashboard Stats;
  fork again
    :Manage Books;
    if (Action?) then (Add)
      :Open AddBooks;
      :Save to DB;
    else (View/Search)
      :Open ViewBooks;
    endif
  fork again
    :Manage Students;
    if (Action?) then (Add)
      :Open AddStudents;
    else (Edit)
      :Open EditStudentInformation;
    endif
  fork again
    :Transactions;
    if (Action?) then (Issue Book)
      :Open IssueBooks;
      :Select Student & Book;
      :Update DB;
    else (Return Book)
      :Open ReturnBooks;
    endif
  end fork
else (Student)
  :Open StudentMenu;
  fork
    :View Personal Dashboard;
  fork again
    :Open ViewBooksStudent;
    :Search/Filter Books;
  end fork
endif

:User Triggers Logout;
:Open LogoutDialog (Animation);
:Return to MainWindow;

stop
@endum

' Sequence diagram
@startuml

actor User

participant MainWindow
participant LoginWindow
participant SignupWindow
participant Database
participant AdminMenu
participant StudentMenu
participant IssueBooks
participant ReturnBooks
participant ViewBooks

== Application Start ==

User -> MainWindow : Start application

alt User chooses Login
    User -> MainWindow : Click "Login"
    MainWindow -> LoginWindow : open()

    User -> LoginWindow : enter credentials
    LoginWindow -> Database : checkLogin(username, password)

    alt Valid credentials
        LoginWindow -> Database : getUserRole(username)

        alt role == admin
            LoginWindow -> AdminMenu : open()

            == Admin Dashboard ==

            alt Issue Book
                AdminMenu -> IssueBooks : open()
                User -> IssueBooks : enter student & book
                IssueBooks -> Database : validate student
                IssueBooks -> Database : validate book
                IssueBooks -> Database : insert issue record
                IssueBooks -> Database : update book status
                IssueBooks --> User : show success
            end

            alt Return Book
                AdminMenu -> ReturnBooks : open()
                User -> ReturnBooks : search student
                ReturnBooks -> Database : loadTransactionsByStudent()
                User -> ReturnBooks : select transaction
                ReturnBooks -> Database : update return_date
                ReturnBooks -> Database : update book status
                ReturnBooks --> User : show confirmation
            end

            alt View Books
                AdminMenu -> ViewBooks : open()
                ViewBooks -> Database : loadBooks()
                ViewBooks --> User : display books
            end

        else role == student
            LoginWindow -> StudentMenu : open()

            == Student Dashboard ==

            StudentMenu -> ViewBooks : open()
            ViewBooks -> Database : loadBooks()
            ViewBooks --> User : display books
        end

    else Invalid credentials
        LoginWindow --> User : show error
    end

else User chooses Signup
    User -> MainWindow : Click "Signup"
    MainWindow -> SignupWindow : open()

    User -> SignupWindow : enter data
    SignupWindow -> Database : addUser()
    SignupWindow --> User : signupSuccessful(student)
end

== Logout ==

User -> AdminMenu : click Logout
AdminMenu -> MainWindow : return to main screen

@enduml

