' State diagram
@startuml
title Library Management System - State Machine Diagram

[*] --> ApplicationClosed

state ApplicationClosed {
}

ApplicationClosed --> Initializing : Launch App
Initializing --> MainWindowState : openConnection() success

state MainWindowState {
    [*] --> Idle
    Idle --> Authenticating : click Login/Signup
}

state Authenticating {
    [*] --> LoginScreen
    LoginScreen --> Verifying : submit credentials
    Verifying --> LoginScreen : [Invalid] / show error
    Verifying --> Authorized : [Valid]
    
    [*] --> SignupScreen
    SignupScreen --> CreatingUser : submit details
    CreatingUser --> Authorized : success (role=student)
}

state Authorized {
    state "AdminSession" as Admin {
        [*] --> AdminDashboard
        AdminDashboard --> ManagingBooks : select Manage
        AdminDashboard --> ManagingStudents : select Manage
        AdminDashboard --> IssuingProcess : select Issue
    }
    
    state "StudentSession" as Student {
        [*] --> StudentDashboard
        StudentDashboard --> BrowsingCatalog : select View Books
    }
}

Authorized --> LogoutDialogState : trigger Logout
LogoutDialogState --> MainWindowState : animation finish

state IssuingProcess {
    [*] --> SelectingDetails
    SelectingDetails --> BookStateUpdate : click Issue
}

' Book Lifecycle within the system
state "Book Status in Database" as BookLife {
    state Available
    state Issued
    state Reserved
    
    Available -right-> Issued : IssueBooks Action
    Issued -left-> Available : ReturnBooks Action
}

MainWindowState --> ApplicationClosed : Close Window
Admin --> ApplicationClosed : Force Close
Student --> ApplicationClosed : Force Close

@endum


