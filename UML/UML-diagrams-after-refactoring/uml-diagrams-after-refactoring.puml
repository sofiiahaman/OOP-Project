' Class diagram
@startuml
skinparam classAttributeIconSize 0
skinparam monochrome true
skinparam shadowing false
skinparam linetype ortho

package "Core & Data" {
    class Database {
        - db : QSqlDatabase
        + Database()
        + openConnection() : bool
        + closeConnection() : void
        + getDb() : QSqlDatabase&
    }

    struct BookSearchParams {
        + title : QString
        + author : QString
        + publisher : QString
        + id : QString
        + category : QString
        + availableOnly : bool
    }

    package "Repositories" {
        class BookRepository {
            - db : Database&
            + addBook(...) : bool
        }
        class StudentRepository {
            - db : Database&
            + findStudentByEmail(...) : int
        }
        class UserRepository {
            - db : Database&
            + checkLogin(...) : bool
        }
        class TransactionRepository {
            - db : Database&
        }
    }
}

package "Service Layer" {
    class AuthService {
        - m_db : Database&
        - m_userRepo : UserRepository
        - m_studentRepo : StudentRepository
        + login(username, password) : QString
        + registerExistingStudent(email, username, password) : QString
    }

    class BookTransactionService {
        - m_db : Database&
        - m_studentRepo : StudentRepository
        - m_bookRepo : BookRepository
        - m_transRepo : TransactionRepository
        + issueBook(studentName, bookId, date) : bool
        + returnBook(transactionId) : bool
    }

    class LibraryService {
        - m_db : Database&
        - m_bookRepo : BookRepository
        + addNewBook(...) : bool
        + searchBooks(...) : QSqlQueryModel*
        + buildFilterString(params : BookSearchParams) : QString
    }
}

package "UI Layer" {
    class MainWindow {
        - db : Database
        - onUserLoggedIn(role : QString)
    }

    class LoginWindow {
        + signupSuccessful(role : QString) <<signal>>
    }

    class SignupWindow {
        + signupSuccessful(role : QString) <<signal>>
    }

    class AdminMenu
    class StudentMenu {
        - ui : Ui::StudentMenu*
        # paintEvent(event : QPaintEvent*)
    }

    abstract class BaseBookView {
        # model : QSqlTableModel*
        # initTableModel(tableName : QString)
        # applySearchFilter(params : BookSearchParams)
        # {abstract} onGoBack()
    }

    class ViewBooks {
        - ui : Ui::ViewBooks*
        # onGoBack() override
    }

    class ViewBooksStudent {
        - ui : Ui::ViewBooksStudent*
        # onGoBack() override
    }

    class ViewStudentInformation {
        - model : QSqlTableModel*
        - loadStudentData(filter : QString)
    }
}

' Inheritance
BaseBookView <|-- ViewBooks
BaseBookView <|-- ViewBooksStudent

' Service -> Repository Relations
AuthService *-- UserRepository
AuthService *-- StudentRepository
BookTransactionService *-- StudentRepository
BookTransactionService *-- BookRepository
BookTransactionService *-- TransactionRepository
LibraryService *-- BookRepository

' UI -> Service Relations
LoginWindow ..> AuthService : uses
SignupWindow ..> AuthService : uses
AdminMenu ..> BookTransactionService : uses
AdminMenu ..> LibraryService : uses

' UI Flow
MainWindow ..> LoginWindow
MainWindow ..> SignupWindow
AdminMenu ..> ViewBooks
StudentMenu ..> ViewBooksStudent

@enduml

' Activity diagram
@startuml
skinparam monochrome true
skinparam shadowing false
skinparam linetype ortho

title Activity Diagram: Complete Library Management System

start

:Start Application (MainWindow);
:Database::openConnection();

if (Connection successful?) then (yes)

    :Display Main Screen;

    if (Select option?) then (Login)

        :Open LoginWindow;
        :Enter username & password;
        :AuthService::login();

        if (Role returned?) then (yes)
            :Emit loginSuccessful(role);
        else (no)
            :Show login error;
            stop
        endif

    else (Signup)

        :Open SignupWindow;
        :Enter email, username, password;
        :AuthService::registerExistingStudent();
        :Emit signupSuccessful("Student");

    endif


    if (Role == "Admin") then (Administrator)

        :Open AdminMenu;
        :loadDashboardStats();
        :StatisticsRepository executes count queries;

        repeat
        if (Choose action?) then (Add Book)

            :Open AddBooks dialog;
            :Enter book data;
            :LibraryService::addNewBook();
            :BookRepository::addBook();

        elseif (View Books)

            :Open ViewBooks;
            :BaseBookView::initTableModel("books");
            :Enter search parameters;
            :LibraryService::buildFilterString();
            :BaseBookView::applySearchFilter();

        elseif (Add Student)

            :Open AddStudents;
            :StudentRepository::addStudent();

        elseif (View Student Info)

            :Open ViewStudentInformation;
            :Load QSqlTableModel;
            :Display students;

        elseif (Edit Student)

            :Open EditStudentInformation;
            :Load students;
            :Select student;
            :StudentRepository::updateStudent();

        elseif (Issue Book)

            :Open IssueBooks;
            :Enter student name & book;
            :BookTransactionService::issueBook();
            :TransactionRepository::addTransaction();
            :BookRepository::updateBookAvailability(false);

        elseif (Return Book)

            :Open ReturnBooks;
            :Select transaction;
            :BookTransactionService::returnBook();
            :TransactionRepository::markAsReturned();
            :BookRepository::updateBookAvailability(true);

        elseif (Logout)

            :Open LogoutDialog;
            break

        endif
        repeat while (Continue working?) is (yes)

        :Close AdminMenu;
        stop

    else (Student)

        :Open StudentMenu;

        repeat
        if (Select action?) then (View Books)

            :Open ViewBooksStudent;
            :BaseBookView::initTableModel("books");
            :Set availableOnly = true;
            :Enter search parameters;
            :LibraryService::buildFilterString();
            :applySearchFilter();

        elseif (Logout)

            break

        endif
        repeat while (Continue?) is (yes)

        :Close StudentMenu;
        stop

    endif

else (no)
    :Show database connection error;
    stop
endif

:Database::closeConnection();
stop

@enduml

