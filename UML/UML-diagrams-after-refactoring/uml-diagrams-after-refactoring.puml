' State diagram
@startuml
skinparam monochrome true
skinparam shadowing false
skinparam linetype ortho

title State Diagram: Library Management System


[*] --> ApplicationStarted

ApplicationStarted : entry / openConnection()

ApplicationStarted --> ConnectionError : connectionFailed
ApplicationStarted --> MainScreen : connectionSuccessful


ConnectionError : entry / showError()
ConnectionError --> [*]


state MainScreen {

    [*] --> WaitingForChoice

    WaitingForChoice --> LoginProcess : selectLogin
    WaitingForChoice --> SignupProcess : selectSignup
}


state LoginProcess {

    [*] --> EnterCredentials

    EnterCredentials --> Authenticating : submit

    Authenticating : do / AuthService.login()

    Authenticating --> LoginFailed : invalidCredentials
    Authenticating --> RoleResolved : validCredentials

    LoginFailed --> EnterCredentials : retry
}


state SignupProcess {

    [*] --> EnterRegistrationData
    EnterRegistrationData --> Registering : submit
    Registering : do / AuthService.registerExistingStudent()
    Registering --> RoleResolved : success
}


RoleResolved --> AdminSession : role == Admin
RoleResolved --> StudentSession : role == Student


' =====================================================
' ADMIN SESSION
' =====================================================

state AdminSession {

    [*] --> Dashboard

    Dashboard : entry / loadDashboardStats()

    Dashboard --> ManageBooks : selectBooks
    Dashboard --> ManageStudents : selectStudents
    Dashboard --> IssueBook : selectIssue
    Dashboard --> ReturnBook : selectReturn
    Dashboard --> ViewStatistics : selectStatistics
    Dashboard --> Logout : selectLogout


    state ManageBooks {
        [*] --> ViewingBooks
        ViewingBooks --> AddingBook : addBook
        AddingBook : do / LibraryService.addNewBook()
        AddingBook --> ViewingBooks
    }

    state ManageStudents {
        [*] --> ViewingStudents
        ViewingStudents --> EditingStudent : editStudent
        EditingStudent : do / StudentRepository.updateStudent()
        EditingStudent --> ViewingStudents
    }

    state IssueBook {
        [*] --> SelectingData
        SelectingData --> ProcessingIssue : confirm
        ProcessingIssue : do / BookTransactionService.issueBook()
        ProcessingIssue --> Dashboard
    }

    state ReturnBook {
        [*] --> SelectingTransaction
        SelectingTransaction --> ProcessingReturn : confirm
        ProcessingReturn : do / BookTransactionService.returnBook()
        ProcessingReturn --> Dashboard
    }

    state ViewStatistics {
        [*] --> LoadingStats
        LoadingStats : do / StatisticsRepository.getCounts()
        LoadingStats --> Dashboard
    }

    Logout --> [*]
}


' =====================================================
' STUDENT SESSION
' =====================================================

state StudentSession {

    [*] --> StudentDashboard

    StudentDashboard --> ViewBooks : selectViewBooks
    StudentDashboard --> Logout : selectLogout

    state ViewBooks {
        [*] --> Searching
        Searching : do / LibraryService.searchBooks()
        Searching --> StudentDashboard
    }

    Logout --> [*]
}


AdminSession --> MainScreen : logout
StudentSession --> MainScreen : logout

MainScreen --> [*] : exitApplication

@enduml

