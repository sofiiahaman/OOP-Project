' Interaction overview diagram
@startuml
skinparam monochrome true
skinparam shadowing false
skinparam conditionStyle diamond

title Interaction Overview Diagram: Library Management System

start

:System initialization;

group **sd: System Login**
    :LoginWindow is displayed;
    :AuthService verifies credentials;
end group

if (Successful authorization?) then (yes)
    if (User role?) then (Administrator)
        partition "Admin Panel (AdminMenu)" {
            repeat
                :Select operation;
                if (Operation?) then (Manage books)
                    group **sd: Book Interaction**
                        :LibraryService::searchBooks();
                        :BaseBookView updates table;
                    end group
                elseif (Issue book)
                    group **sd: Issue Transaction**
                        :BookTransactionService::issueBook();
                        :Update statuses in database;
                    end group
                else (Edit students)
                    :EditStudentInformation;
                endif
            repeat while (Continue?) is (yes)
        }
    else (Student)
        partition "Student Portal (StudentMenu)" {
            group **sd: Search and View**
                :ViewBooksStudent;
                :LibraryService::buildFilterString();
            end group
        }
    endif
else (no)
    :Show error message;
    stop
endif

group **sd: System Shutdown**
    :LogoutDialog;
    :Database::closeConnection();
end group

stop
@enduml


